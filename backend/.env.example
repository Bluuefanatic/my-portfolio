# Backend Environment Variables

# Port the backend runs on (default: 3000)
PORT=3000

# Node environment (development or production)
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration (required for production contact form)
# Service provider: gmail, outlook, yahoo, etc.
EMAIL_SERVICE=gmail

# Email credentials - create an app password for Gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Contact email address where inquiries are sent
CONTACT_EMAIL=izirenjoel@gmail.com

# Portfolio owner name for email signature
OWNER_NAME=Joel Iziren

# Send auto-reply to users (true/false)
SEND_AUTO_REPLY=true
